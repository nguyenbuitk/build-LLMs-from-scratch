    "import importlib\n",
    "import tiktoken\n",
    "\n",
    "tokenizer = tiktoken.get_encoding(\"gpt2\")\n",
    "vocab = { 'a': 1, 'b': 2, 'c': 3}\n",
    "if 'd' in vocab:\n",
    "  print('true')\n",
    "  \n",
    "ids = tokenizer.encode(\"hello, world!\")\n",
    "print(ids)\n",
    "tokenizer.decode([1223])\n",
    "\n",
    "\n",
    "for i in range(0, 5):\n",
    "  print(i)"
   ]
